# the single checkpoint predict_board() loads (negated below).
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx

# ---- KEEP the submission checkpoint (negate the ignore above) ----
!submission/checkpoints/
!submission/checkpoints/best_real.pt
